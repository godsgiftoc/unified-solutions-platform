# ---- Unified Solutions Platform: environment template ----
# Copy to .env and fill in. NEVER commit the real .env.

# App
USP_ENV=development
USP_API_HOST=0.0.0.0
USP_API_PORT=8000
USP_FRONTEND_ORIGIN=http://localhost:5173

# Master key for envelope encryption of connection secrets.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
USP_MASTER_KEY=replace-me-with-a-fernet-key

# Session signing secret (opaque sessions live in Redis; this signs the cookie id)
USP_SESSION_SECRET=replace-me-with-a-random-string

# Postgres (metadata DB)
USP_POSTGRES_HOST=localhost
USP_POSTGRES_PORT=5432
USP_POSTGRES_USER=usp
USP_POSTGRES_PASSWORD=usp
USP_POSTGRES_DB=usp

# Redis (sessions / cache / arq broker)
USP_REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO / S3-compatible) for raw + materialized Parquet, uploads, artifacts
USP_S3_ENDPOINT=http://localhost:9000
USP_S3_ACCESS_KEY=minioadmin
USP_S3_SECRET_KEY=minioadmin
USP_S3_BUCKET=usp-data
USP_S3_REGION=us-east-1

# Google OIDC (optional in dev — local auth fallback works without it)
USP_GOOGLE_CLIENT_ID=
USP_GOOGLE_CLIENT_SECRET=
# Restrict sign-in to a single Google Workspace domain (leave blank to allow any)
USP_GOOGLE_HOSTED_DOMAIN=
